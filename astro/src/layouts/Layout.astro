---
import '../styles/global.css'

const cfToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const beaconData = JSON.stringify({ token: cfToken });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>Ransom Williams</title>
    <!-- added initial-scale=1.  what does it do? -->
		<meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- todo: does meta data help seo? do i care about seo? -->
		<meta name="generator" content={Astro.generator} />
	{cfToken && (
  <script 
    is:inline 
    defer 
    src="https://cloudflareinsights.com" 
    data-cf-beacon={beaconData}
  ></script>
)}
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
